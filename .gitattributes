# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Force LF for shell scripts (must not have CRLF)
*.sh text eol=lf

# Force LF for Python and SQL
*.py text eol=lf
*.sql text eol=lf

# Force LF for config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files - no line ending conversion
*.parquet binary
*.png binary
*.jpg binary
